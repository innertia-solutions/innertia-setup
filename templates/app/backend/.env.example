APP_NAME={{PROJECT_NAME}}
APP_ENV=local
APP_KEY=
JWT_SECRET=
APP_DEBUG=true
APP_URL=http://localhost:{{APP_PORT}}
FRONTEND_URL=http://localhost:{{FRONTEND_PORT}}

DB_CONNECTION=pgsql
DB_HOST=database
DB_PORT=5432
DB_DATABASE={{PROJECT_NAME}}
DB_USERNAME=root
DB_PASSWORD={{DB_PASSWORD}}

CACHE_STORE=redis
REDIS_HOST=redis
REDIS_PORT=6379

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

FILESYSTEM_DISK=local
FILESYSTEM_CLOUD=r2

CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET={{PROJECT_NAME}}
CLOUDFLARE_R2_PRIVATE_BUCKET={{PROJECT_NAME}}-private
CLOUDFLARE_R2_PUBLIC_URL=


# Application version — shown in Olimpo health check
APP_VERSION=1.0.0

# Olimpo — admin panel integration
OLIMPO_KEY=
OLIMPO_URL=

# Telemetry — framework metrics sent to Olimpo
TELEMETRY_ENABLED=false
TELEMETRY_MODE=remote

# Mail branding
MAIL_LOGO_URL=
MAIL_BRAND_COLOR=#6366f1
MAIL_LOGIN_PATH=/login
